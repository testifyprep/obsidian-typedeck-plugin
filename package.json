{
  "name": "obsidian-typedeck-plugin",
  "version": "1.0.1",
  "description": "Obsidian plugin for Typedeck — slide delimiter visualization, slide count, format validation, and Open in Typedeck",
  "main": "main.js",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production"
  },
  "keywords": ["obsidian", "typedeck", "presentation", "slides"],
  "license": "MIT",
  "devDependencies": {
    "@codemirror/state": "6.5.0",
    "@codemirror/view": "6.35.3",
    "@types/node": "^16.11.6",
    "builtin-modules": "3.3.0",
    "esbuild": "0.17.3",
    "obsidian": "latest",
    "tslib": "2.4.0",
    "typescript": "^5.0.0"
  }
}
